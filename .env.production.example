# ==============================================================
# SeHerbal - Environment Variables untuk Vercel (Production)
# ==============================================================
# CARA PAKAI:
# Salin semua variabel ini ke Vercel Dashboard:
# Project → Settings → Environment Variables
# ==============================================================

# === APP CONFIG ===
APP_NAME=SeHerbal
APP_ENV=production
APP_KEY=                          # ← Jalankan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://seherbal.vercel.app   # ← Ganti dengan URL Vercel kamu

# === LOGGING ===
LOG_CHANNEL=stderr
LOG_LEVEL=error

# === DATABASE (PlanetScale) ===
# Daftar gratis di: https://planetscale.com
# Buat database baru → Connect → pilih Laravel → copy credentials
DB_CONNECTION=mysql
DB_HOST=          # ← Dari PlanetScale (contoh: aws.connect.psdb.cloud)
DB_PORT=3306
DB_DATABASE=      # ← Nama database di PlanetScale
DB_USERNAME=      # ← Username PlanetScale
DB_PASSWORD=      # ← Password PlanetScale
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt   # ← Wajib untuk PlanetScale SSL

# === CACHE & SESSION (Wajib untuk Serverless) ===
CACHE_DRIVER=array
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
BROADCAST_DRIVER=log

# === CLOUDINARY (Image Storage) ===
# Daftar gratis di: https://cloudinary.com
# Dashboard → API Keys → copy credentials
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>

# === GEMINI AI ===
GEMINI_API_KEY=   # ← API key Gemini kamu (sudah ada di .env lokal)

# === ADMIN ===
ADMIN_EMAIL=      # ← Email admin
ADMIN_PASSWORD=   # ← Password admin

# === VITE (tidak diperlukan di production) ===
VITE_APP_NAME="${APP_NAME}"
